<div class="bg-white">
    <button id="counter-btn">Add 1</button>
    <p>Count is: <span id="count-display">0</span></p>
</div>

<script>
    // Typ für die Zählervariable
    let count: number = 0;

    // Typen für die HTML-Elemente, die wir verwenden
    const button: HTMLButtonElement | null = document.getElementById('counter-btn') as HTMLButtonElement | null;
    const countDisplay: HTMLSpanElement | null = document.getElementById('count-display') as HTMLSpanElement | null;

    if (button && countDisplay) { // Sicherstellen, dass die Elemente nicht null sind
        button.addEventListener('click', () => {
            count++; // Erhöhe den Zähler
            countDisplay.textContent = count.toString(); // Zahl in einen String konvertieren
        });
    } else {
        console.error('Button or count display element not found.');
    }
</script>